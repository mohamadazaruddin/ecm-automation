<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>Case Links with Analyst & QC</title>
    <style>
      :root {
        --bg: #0b0f14;
        --text: #e6eef8;
        --muted: #9fb0c3;
        --link: #75787b;
        --node: #62b5e5;
        --nodeHover: #86bc25;
      }
      html,
      body {
        height: 100%;
        margin: 0;
        background: var(--bg);
        color: var(--text);
        font-family:
          ui-sans-serif,
          system-ui,
          -apple-system,
          Segoe UI,
          Roboto,
          Arial;
      }
      header {
        padding: 10px 14px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.08);
        color: var(--muted);
        font-size: 12px;
      }
      #stage {
        height: calc(100% - 41px);
      }
      svg {
        width: 100%;
        height: 100%;
        display: block;
      }

      .link-line {
        stroke: var(--link);
        stroke-width: 1.6;
        opacity: 0.9;
      }
      .link-label {
        fill: var(--text);
        font-size: 11px;
        opacity: 0.92;
        paint-order: stroke;
        stroke: rgba(11, 15, 20, 0.9);
        stroke-width: 3px;
      } /* faux background */

      .node circle {
        fill: var(--node);
        stroke: rgba(255, 255, 255, 0.22);
        stroke-width: 1;
      }
      .node text {
        fill: var(--text);
        font-size: 12px;
        pointer-events: none;
      }
      .node:hover circle {
        fill: var(--nodeHover);
      }
    </style>
  </head>
  <body>
    <header>Drag nodes. Link labels show “Analyst / QC”.</header>

    <div id="stage">
      <svg id="svg" viewBox="0 0 1000 650" aria-label="Case relationship graph">
        <g id="links"></g>
        <g id="nodes"></g>
      </svg>
    </div>

    <script>
      // Code Generated by Sidekick is for learning and experimentation purposes only.
      const data = [
        { "base case": 233, "related case": 272, Analyst: "Azar", Qc: "sweta" },
        {
          "base case": 455,
          "related case": 567,
          Analyst: "shreya",
          Qc: "sweta",
        },
        {
          "base case": 678,
          "related case": 987,
          Analyst: "vijay",
          Qc: "pragya",
        },
        { "base case": 233, "related case": 498, Analyst: "dev", Qc: "surya" },
        {
          "base case": 678,
          "related case": 123,
          Analyst: "puneet",
          Qc: "omkar",
        },
        {
          "base case": 677,
          "related case": 465,
          Analyst: "rishi",
          Qc: "smruti",
        },
      ];

      // Build nodes + links (Analyst/Qc live on links/relationships)
      const nodeIds = new Set();
      const baseCaseIds = new Set();
      const relatedCaseIds = new Set();

      const links = data.map((row) => {
        const source = String(row["base case"]);
        const target = String(row["related case"]);

        nodeIds.add(source);
        nodeIds.add(target);

        baseCaseIds.add(source);
        relatedCaseIds.add(target);

        return {
          source,
          target,
          analyst: row["Analyst"] ? `An: ${row["Analyst"]}` : "",
          qc: row["Qc"] ? `QC: ${row["Qc"]}` : "",
        };
      });

      const nodes = Array.from(nodeIds).map((id) => {
        const isBase = baseCaseIds.has(id);
        const isRelated = relatedCaseIds.has(id);

        const role =
          isBase && isRelated
            ? "base+related"
            : isBase
              ? "base"
              : isRelated
                ? "related"
                : "unknown";

        return {
          id,
          label: `Case ${id} (${role})`,
          isBase,
          isRelated,
          role,
        };
      });
      // Simple layout (circle)
      const W = 1000,
        H = 650;
      const cx = W / 2,
        cy = H / 2,
        r = Math.min(W, H) * 0.34;

      nodes.forEach((n, i) => {
        const a = (i / nodes.length) * Math.PI * 2;
        n.x = cx + Math.cos(a) * r;
        n.y = cy + Math.sin(a) * r;
      });

      const nodeById = new Map(nodes.map((n) => [n.id, n]));

      // Render
      const svg = document.getElementById("svg");
      const linksG = document.getElementById("links");
      const nodesG = document.getElementById("nodes");

      // Links: <g><line/><text/></g>
      const linkEls = links.map((l) => {
        const g = document.createElementNS("http://www.w3.org/2000/svg", "g");

        const line = document.createElementNS(
          "http://www.w3.org/2000/svg",
          "line",
        );
        line.classList.add("link-line");

        // Native tooltip on hover
        const title = document.createElementNS(
          "http://www.w3.org/2000/svg",
          "title",
        );
        title.textContent = `Analyst: ${l.analyst || "-"} | QC: ${l.qc || "-"}`;
        line.appendChild(title);

        const text = document.createElementNS(
          "http://www.w3.org/2000/svg",
          "text",
        );
        text.classList.add("link-label");
        text.setAttribute("text-anchor", "middle");
        text.textContent = `${l.analyst || "-"} / ${l.qc || "-"}`;

        g.appendChild(line);
        g.appendChild(text);
        linksG.appendChild(g);

        return { g, line, text, l };
      });

      const nodeEls = nodes.map((n) => {
        const g = document.createElementNS("http://www.w3.org/2000/svg", "g");
        g.classList.add("node");
        g.style.cursor = "grab";

        const c = document.createElementNS(
          "http://www.w3.org/2000/svg",
          "circle",
        );
        c.setAttribute("r", "18");

        const t = document.createElementNS(
          "http://www.w3.org/2000/svg",
          "text",
        );
        t.setAttribute("x", "24");
        t.setAttribute("y", "4");
        t.textContent = n.label;

        g.appendChild(c);
        g.appendChild(t);
        nodesG.appendChild(g);

        g.addEventListener("pointerdown", (e) => startDrag(e, n, g));
        return { g, n };
      });

      function redraw() {
        for (const { g, n } of nodeEls)
          g.setAttribute("transform", `translate(${n.x},${n.y})`);

        for (const { line, text, l } of linkEls) {
          const s = nodeById.get(l.source),
            t = nodeById.get(l.target);
          if (!s || !t) continue;

          line.setAttribute("x1", s.x);
          line.setAttribute("y1", s.y);
          line.setAttribute("x2", t.x);
          line.setAttribute("y2", t.y);

          const mx = (s.x + t.x) / 2;
          const my = (s.y + t.y) / 2;

          // Offset label slightly so it doesn’t sit on the line
          text.setAttribute("x", mx);
          text.setAttribute("y", my - 6);
        }
      }
      redraw();

      // Dragging
      let drag = null;

      function startDrag(e, node, g) {
        g.setPointerCapture(e.pointerId);
        g.style.cursor = "grabbing";
        const pt = toSvgPoint(e.clientX, e.clientY);
        drag = {
          node,
          g,
          dx: node.x - pt.x,
          dy: node.y - pt.y,
          pid: e.pointerId,
        };

        g.addEventListener("pointermove", onDragMove);
        g.addEventListener("pointerup", endDrag, { once: true });
        g.addEventListener("pointercancel", endDrag, { once: true });
      }

      function onDragMove(e) {
        if (!drag || e.pointerId !== drag.pid) return;
        const pt = toSvgPoint(e.clientX, e.clientY);
        drag.node.x = clamp(pt.x + drag.dx, 30, W - 30);
        drag.node.y = clamp(pt.y + drag.dy, 30, H - 30);
        redraw();
      }

      function endDrag(e) {
        if (!drag || e.pointerId !== drag.pid) return;
        drag.g.style.cursor = "grab";
        drag.g.removeEventListener("pointermove", onDragMove);
        drag = null;
      }

      function toSvgPoint(clientX, clientY) {
        const p = svg.createSVGPoint();
        p.x = clientX;
        p.y = clientY;
        const ctm = svg.getScreenCTM();
        return ctm
          ? p.matrixTransform(ctm.inverse())
          : { x: clientX, y: clientY };
      }

      function clamp(v, lo, hi) {
        return Math.max(lo, Math.min(hi, v));
      }
    </script>
  </body>
</html>
